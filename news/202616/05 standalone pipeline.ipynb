     "title": "Create materialized view from sale_refund"
    }
   },
   "outputs": [],
   "source": [
    "CREATE OR REPLACE MATERIALIZED VIEW hub.default.mv_daily_refund\n",
    "CLUSTER BY (tx_date)\n",
    "SCHEDULE EVERY 1 WEEK\n",
    "AS\n",
    "SELECT\n",
    "  DATE(tx_ts) AS tx_date,\n",
    "  SUM(amount) AS total_amount\n",
    "FROM hub.default.sale_refund\n",
    "GROUP BY DATE(tx_ts)"
   ]
  },
